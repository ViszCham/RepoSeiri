{
  "schema_version": "reposeiri.r10-sip.v1",
  "protocol": "R10-SIP-v1",
  "roadmap": "docs/design/roadmap-v10-closure-and-product-integrity.md",
  "protocol_document": "docs/design/r10-sip-v1-protocol.md",
  "trigger_phrases": [
    "R10-SIP-v1でC0-C8を一括実装してください",
    "R10-SIP-v1を実行してください",
    "Implement C0-C8 as one batch under R10-SIP-v1",
    "Execute R10-SIP-v1"
  ],
  "units": [
    {
      "id": "C0",
      "name": "truthful_closure",
      "depends_on": []
    },
    {
      "id": "C1",
      "name": "bounded_source_session",
      "depends_on": [
        "C0"
      ]
    },
    {
      "id": "C2",
      "name": "stable_identity",
      "depends_on": [
        "C1"
      ]
    },
    {
      "id": "C3",
      "name": "contract_closure",
      "depends_on": [
        "C2"
      ]
    },
    {
      "id": "C4",
      "name": "extension_completion",
      "depends_on": [
        "C3"
      ]
    },
    {
      "id": "C5",
      "name": "semantic_markdown_and_consistency",
      "depends_on": [
        "C4"
      ]
    },
    {
      "id": "C6",
      "name": "product_surface",
      "depends_on": [
        "C5"
      ]
    },
    {
      "id": "C7",
      "name": "verification_and_release_engineering",
      "depends_on": [
        "C6"
      ]
    },
    {
      "id": "C8",
      "name": "empirical_calibration_and_completion",
      "depends_on": [
        "C7"
      ]
    }
  ],
  "authority_defaults": {
    "analysis": true,
    "mutation": true,
    "verification": true,
    "ledger": true,
    "commit": false,
    "push": false,
    "merge": false,
    "release": false,
    "publication": false,
    "visibility": false,
    "plugin_install": false,
    "restart": false
  },
  "execution": {
    "mode": "continuous_noninteractive",
    "max_in_progress_slices": 1,
    "ledger_path": "target/r10-sip/<execution-id>/state.json",
    "intermediate_commits": false,
    "midrun_user_prompt": false,
    "stop_on_first_failure": false,
    "continue_independent_after_block": true,
    "blocking_checks_may_be_skipped": false,
    "blocked_checks_may_be_promoted": false,
    "user_change_policy": "preserve_reconcile_or_block_affected_slice",
    "source_drift_rebaseline_limit": 1,
    "local_repair_limit_per_slice": 3,
    "owner_backflow_limit": 2,
    "global_repair_limit": 24,
    "unchanged_error_retry_limit": 1
  },
  "failure_policies": {
    "local_repairable": "repair_and_retry",
    "contract_regression": "backflow_to_owner",
    "cross_unit_regression": "reopen_minimum_affected_units",
    "source_drift": "rebaseline_once",
    "environment_blocked": "record_and_continue_independent",
    "authority_required": "block_affected_and_continue",
    "user_overlap": "preserve_reconcile_or_block_affected",
    "privacy_boundary": "remove_protocol_leak_preserve_user_source_run_privacy_regression_and_continue",
    "unsupported_design_decision": "conservative_existing_contract_or_block",
    "non_repairable": "block_dependency_cone_and_continue_diagnostics"
  },
  "slice_states": [
    "pending",
    "in_progress",
    "repairing",
    "backflow_pending",
    "passed",
    "blocked_environment",
    "blocked_authority",
    "blocked_privacy",
    "blocked_conflict",
    "blocked_dependency",
    "superseded"
  ],
  "final_states": [
    "ready_for_git",
    "implemented_with_blocked_evidence",
    "incomplete"
  ],
  "evidence_states": [
    "implemented",
    "locally_verified",
    "host_verified",
    "calibrated",
    "evidence_complete"
  ],
  "completion": {
    "finding_zero_is_sufficient": false,
    "requires_complete_primary_coverage": true,
    "requires_zero_unacknowledged_unknown": true,
    "requires_zero_budget_exhaustion": true,
    "requires_complete_conflict_coverage": true,
    "requires_same_source_binding": true,
    "requires_stable_identity_properties": true,
    "requires_contract_revision_parity": true,
    "requires_extension_positive_negative_privacy_tests": true,
    "requires_markdown_and_bilingual_corpora": true,
    "requires_product_surface_parity": true,
    "requires_local_verification": true,
    "requires_windows_and_linux_receipts_for_evidence_complete": true,
    "requires_holdout_uncertainty_for_calibrated": true
  },
  "privacy": {
    "store_source_bodies": false,
    "store_diff_bodies": false,
    "store_private_analysis_filename": false,
    "store_private_analysis_body": false,
    "store_private_calibration_values": false,
    "store_private_digest": false,
    "store_host_absolute_paths": false,
    "store_credentials": false
  }
}
