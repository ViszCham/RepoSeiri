{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reposeiri.invalid/schemas/seiri.executable-pattern-pack.v2.json",
  "title": "RepoSeiri executable pattern pack v2",
  "schema_version": "seiri.executable-pattern-pack.v2",
  "owner": "seiri-patterns::ExecutablePatternPack",
  "compatibility": "v2-only",
  "adoption": "maintainer_review_required",
  "type": "object",
  "required": ["schema_version", "id", "version", "definitions", "fixtures"],
  "properties": {
    "schema_version": { "const": "seiri.executable-pattern-pack.v2" },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "version": { "type": "string", "minLength": 1, "maxLength": 128 },
    "definitions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/definition" }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": { "$ref": "#/$defs/fixture" }
    }
  },
  "$defs": {
    "definition": {
      "type": "object",
      "required": ["id", "group", "predicate", "boundaries", "adoption_stage"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "group": { "type": "string" },
        "predicate": {
          "type": "object",
          "required": ["atoms", "instructions"],
          "properties": {
            "atoms": {
              "type": "array",
              "maxItems": 128,
              "items": {
                "type": "object",
                "required": ["kind", "data"],
                "properties": {
                  "kind": { "enum": ["evidence", "document_role", "route_content"] },
                  "data": {}
                },
                "additionalProperties": false
              }
            },
            "instructions": {
              "type": "array",
              "maxItems": 256,
              "items": {
                "type": "object",
                "required": ["op"],
                "properties": {
                  "op": { "enum": ["push_atom", "all", "any", "at_least"] },
                  "data": {}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "boundaries": {
          "type": "array",
          "minItems": 2,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "type": "string" },
          "contains": { "const": "not_automatic_policy_adoption" }
        },
        "adoption_stage": { "const": "candidate" },
        "enabled": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "fixture": {
      "type": "object",
      "required": ["id", "kind", "group", "root", "expectations"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "kind": { "enum": ["positive", "negative", "ambiguous", "partial", "malformed"] },
        "group": { "type": "string" },
        "root": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "not": { "pattern": "(^[/\\\\])|(^[A-Za-z]:)|(^|[/\\\\])\\.\\.([/\\\\]|$)" }
        },
        "expectations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["pattern", "coverage", "gap", "claim_boundary", "diagnostic"] },
              "pattern": { "type": "string" },
              "outcome": {},
              "evidence": {},
              "scope": {},
              "status": {},
              "gap": {},
              "minimum": { "type": "integer", "minimum": 0 },
              "maximum": { "type": "integer", "minimum": 0 },
              "boundary": {},
              "present": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "scan_budget": {
          "type": "object",
          "required": ["max_depth", "max_entries", "max_file_bytes", "max_total_bytes"],
          "properties": {
            "max_depth": { "type": "integer", "minimum": 1, "maximum": 32 },
            "max_entries": { "type": "integer", "minimum": 1, "maximum": 100000 },
            "max_file_bytes": { "type": "integer", "minimum": 1, "maximum": 2097152 },
            "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 33554432 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
